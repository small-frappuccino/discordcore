{
  "servers": {
    "smallfrappuccinoDiscordcore": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/../smallfrappuccino-mcp/node_modules/tsx/dist/cli.mjs",
        "${workspaceFolder}/../smallfrappuccino-mcp/src/index.ts",
        "--repo-root",
        "${workspaceFolder}",
        "--server-name",
        "smallfrappuccino_discordcore",
        "--db-path",
        "${workspaceFolder}/.mcp/smallfrappuccino-discordcore.sqlite"
      ]
    },
    "smallfrappuccinoDiscordcoreBuilt": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/../smallfrappuccino-mcp/dist/index.js",
        "--repo-root",
        "${workspaceFolder}",
        "--server-name",
        "smallfrappuccino_discordcore_built",
        "--db-path",
        "${workspaceFolder}/.mcp/smallfrappuccino-discordcore.sqlite"
      ]
    }
  }
}
