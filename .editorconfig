root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs; gofmt enforces this and requires LF.
[*.go]
indent_style = tab
indent_size = 4

# Go module files mirror Go source conventions.
[{go.mod,go.sum}]
indent_style = tab
indent_size = 4

# Makefiles require tabs.
[Makefile]
indent_style = tab
indent_size = 4

# Windows-only scripts keep CRLF and PowerShell's preferred indent.
[*.{ps1,bat,cmd}]
end_of_line = crlf
indent_style = space
indent_size = 4
