# Default: detect text vs binary; commit text with LF line endings.
# Working-tree checkout uses LF on every platform so editors stay
# consistent and gofmt/Prettier do not produce drift commits.
* text=auto eol=lf

# Go source. gofmt rewrites CRLF, so anything tracked must be LF.
*.go    text eol=lf
go.mod  text eol=lf
go.sum  text eol=lf

# Frontend and shared text formats.
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.env   text eol=lf
Makefile text eol=lf

# Windows-only scripts keep CRLF — that is the platform convention
# and PowerShell hosts on older Windows can stumble on LF here.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Common binary asset types — never run text normalization on these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text eol=lf
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.tgz   binary
*.7z    binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.wav   binary
